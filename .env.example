# Copy to .env and fill in values. Never commit .env.

NODE_ENV=development
PORT=5000

# Required: MongoDB connection string (Prisma). Use Atlas or another reachable cluster.
DATABASE_URL="mongodb+srv://user:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority"

# Required for auth
JWT_ACCESS_SECRET=change-me-min-32-chars
JWT_REFRESH_SECRET=change-me-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS + emails (use your frontend URL)
CLIENT_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Behind reverse proxy (Caddy/Nginx) — set true in production with Docker+Caddy
TRUST_PROXY=false

# Optional: rate limiting (default off in dev unless set to true)
IS_RATE_LIMIT_ACTIVE=false

# Optional: Redis / Kafka (set IS_*_ACTIVE=true only if you run those services)
IS_REDIS_ACTIVE=false
REDIS_URL=redis://localhost:6379
IS_KAFKA_ACTIVE=false
KAFKA_BROKERS=localhost:9092

# Email (Resend)
EMAIL_FROM=no-reply@example.com
RESEND_API_KEY=

# UploadThing
UPLOADTHING_TOKEN=

# Fapshi payments (see .env.fapshi.example)
FAPSHI_API_KEY=
FAPSHI_API_USER=
FAPSHI_BASE_URL=https://sandbox.fapshi.com
FAPSHI_WEBHOOK_SECRET=

# Used by cron health ping to self (optional; e.g. Render keep-alive)
API_URL=http://localhost:5000

# Web Push (browser notifications for TIC Community) — optional
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BKlBDGSFiQ7hrgGUcLnLqctqOjyivdLiuJ8kesyoCRyftAuAw8XkPFD7UeyU6P-2fJgfsiFIZPlO7CQ4vSEAvQ8
VAPID_PRIVATE_KEY=rLk-QZIJxO_atBKa71havjyyGwLDYeBfqU2Y2rF5rII
VAPID_SUBJECT=mailto:no-reply@ticsummit.org
NEXT_PUBLIC_WS_URL=http://localhost:5005

# Logging
LOG_LEVEL=info
